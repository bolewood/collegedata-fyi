# collegedata.fyi — environment variables
#
# Copy this file to .env and fill in the real values.
# .env is gitignored; .env.example is committed as a template.
#
# Most values come from your Supabase project dashboard:
# https://app.supabase.com/project/<ref>/settings/api
# https://app.supabase.com/project/<ref>/settings/database

# ─── Supabase project identity ──────────────────────────────────────────────
# Project ref: the random string in your Supabase dashboard URL.
SUPABASE_PROJECT_REF=your-project-ref-here

# Project URL: https://<ref>.supabase.co
SUPABASE_URL=https://your-project-ref-here.supabase.co

# ─── Supabase API keys ──────────────────────────────────────────────────────
# Anon (public) key — safe to expose in client-side code and docs.
# Used by PostgREST for unauthenticated reads against tables with public policies.
# Dashboard: Settings > API > anon public
SUPABASE_ANON_KEY=

# Service role key — NEVER commit, NEVER expose client-side.
# Bypasses Row-Level Security. Used by the Python worker and edge functions
# for writes to the manifest and Storage.
# Dashboard: Settings > API > service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# ─── Supabase database ──────────────────────────────────────────────────────
# Database password: set during project creation. Needed by `supabase db push`
# for direct Postgres access. If you don't remember it, reset it in the
# dashboard: Settings > Database > Reset Database Password.
SUPABASE_DB_PASSWORD=

# Direct Postgres connection string, useful for psql / pgcli / pgAdmin.
# Format: postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
# Dashboard: Settings > Database > Connection String > URI
DATABASE_URL=

# ─── Supabase access token (optional) ───────────────────────────────────────
# Personal access token for `supabase` CLI commands that hit the Management API
# (e.g., creating/deleting projects via CLI). Not required for routine migration
# work if you use `supabase login` interactively.
# Dashboard: https://app.supabase.com/account/tokens
SUPABASE_ACCESS_TOKEN=
